# Copy this file to test.env and fill in real values.
# test.env is gitignored — never commit credentials.
#
# API_URL and API_KEY_s must point at the dedicated TEST Supabase project, not production.

API_URL=https://your-test-project.supabase.co
API_KEY_s=your-test-service-role-key

# Bootstrap superAdmin — created once manually in the test Supabase project
# (via the dashboard or a one-off script). Never deleted by the test suite.
# The reset endpoint reads SUPER_ADMIN_EMAIL to know which auth user to skip
# during deletion. SUPER_ADMIN_PASSWORD is used by conftest.py to sign in
# and obtain a JWT for calling admin endpoints.
SUPER_ADMIN_EMAIL=test_superadmin@test.com
SUPER_ADMIN_PASSWORD=YourSuperAdminPassword123!

# Shared password assigned to all four seeded test accounts.
# Matches the DEFAULT_PASSWORD used by seed_data.py (reads TEST_PASSWORD env var).
TEST_PASSWORD=TestPassword123!

# Email addresses for the four test accounts created at runtime by reset_and_seed.
# These accounts are deleted and re-created at the start of each test session.

# Regular user — reports matches, can confirm matches they did not report
TEST_USER1_EMAIL=test_user1@test.com

# Regular user — the other participant
TEST_USER2_EMAIL=test_user2@test.com

# Regular user — NOT a participant in most test matches (used for 403 tests)
TEST_USER3_EMAIL=test_user3@test.com

# Admin user (role_id = 2) — can confirm/reject any match
TEST_ADMIN_EMAIL=test_admin@test.com
